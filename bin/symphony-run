#!/usr/bin/env bash
set -euo pipefail

usage() {
  printf 'Usage: %s <project> [--maestro]\n' "${0##*/}" >&2
}

die() {
  printf 'symphony-run: %s\n' "$*" >&2
  exit 1
}

github_app_configured() {
  github_app_any=0
  github_app_missing=""

  for github_app_var in GITHUB_APP_ID GITHUB_APP_INSTALLATION_ID GITHUB_APP_PRIVATE_KEY_PATH; do
    if [ -n "${!github_app_var:-}" ]; then
      github_app_any=1
    else
      github_app_missing="$github_app_missing $github_app_var"
    fi
  done

  [ "$github_app_any" -eq 1 ] || return 1
  [ -z "$github_app_missing" ] || die "GitHub App env is incomplete; missing:${github_app_missing}"
}

github_app_jwt() {
  ruby -rbase64 -rjson -ropenssl -e '
    app_id, key_path = ARGV
    now = Time.now.to_i

    def base64url(value)
      Base64.urlsafe_encode64(value).delete("=")
    end

    header = base64url({ alg: "RS256", typ: "JWT" }.to_json)
    payload = base64url({ iat: now - 60, exp: now + 540, iss: app_id }.to_json)
    body = "#{header}.#{payload}"
    key = OpenSSL::PKey::RSA.new(File.read(key_path))
    signature = base64url(key.sign(OpenSSL::Digest::SHA256.new, body))
    puts "#{body}.#{signature}"
  ' "$GITHUB_APP_ID" "$GITHUB_APP_PRIVATE_KEY_PATH"
}

github_app_json_field() {
  ruby -rjson -e '
    value = JSON.parse(STDIN.read)
    ARGV.fetch(0).split(".").each { |key| value = value.fetch(key) }
    exit 1 if value.nil? || value.to_s.empty?
    puts value
  ' "$1"
}

github_app_api() {
  local method="$1"
  local path="$2"
  local jwt="$3"
  local api_url="${GITHUB_API_URL:-https://api.github.com}"
  local tmp_body status preview

  tmp_body="$(mktemp)"
  if ! status="$(
    curl -sS -L -o "$tmp_body" -w "%{http_code}" -X "$method" \
      -H "Accept: application/vnd.github+json" \
      -H "Authorization: Bearer $jwt" \
      -H "X-GitHub-Api-Version: 2022-11-28" \
      "$api_url$path"
  )"; then
    rm -f "$tmp_body"
    die "GitHub App API request failed: $method $path"
  fi

  if [[ "$status" != 2* ]]; then
    preview="$(head -c 400 "$tmp_body" | tr '\n' ' ')"
    rm -f "$tmp_body"
    die "GitHub App API request failed ($status): $method $path: $preview"
  fi

  cat "$tmp_body"
  rm -f "$tmp_body"
}

configure_github_app_auth() {
  github_app_configured || return 0

  [ -r "$GITHUB_APP_PRIVATE_KEY_PATH" ] || die "GITHUB_APP_PRIVATE_KEY_PATH is not readable: $GITHUB_APP_PRIVATE_KEY_PATH"
  command -v ruby >/dev/null 2>&1 || die "ruby is required to mint a GitHub App token"
  command -v curl >/dev/null 2>&1 || die "curl is required to mint a GitHub App token"

  local jwt installation_json token_json installation_account app_slug token bot_name bot_email

  jwt="$(github_app_jwt)" || die "failed to sign GitHub App JWT"
  installation_json="$(github_app_api GET "/app/installations/$GITHUB_APP_INSTALLATION_ID" "$jwt")"
  installation_account="$(printf '%s' "$installation_json" | github_app_json_field account.login)" ||
    die "GitHub App installation response did not include account.login"
  app_slug="$(printf '%s' "$installation_json" | github_app_json_field app_slug 2>/dev/null || true)"

  token_json="$(github_app_api POST "/app/installations/$GITHUB_APP_INSTALLATION_ID/access_tokens" "$jwt")"
  token="$(printf '%s' "$token_json" | github_app_json_field token)" ||
    die "GitHub App access token response did not include token"

  export GH_TOKEN="$token"
  export GITHUB_TOKEN="$token"
  export GITHUB_FORK_OWNER="$installation_account"

  bot_name="${GITHUB_APP_BOT_NAME:-}"
  [ -n "$bot_name" ] || bot_name="${app_slug:-github-app}[bot]"
  bot_email="${GITHUB_APP_BOT_EMAIL:-$bot_name@users.noreply.github.com}"

  export GIT_AUTHOR_NAME="$bot_name"
  export GIT_AUTHOR_EMAIL="$bot_email"
  export GIT_COMMITTER_NAME="$bot_name"
  export GIT_COMMITTER_EMAIL="$bot_email"
}

maestro_mode=0
positional=()
for arg in "$@"; do
  case "$arg" in
    --maestro) maestro_mode=1 ;;
    -*)
      usage
      exit 64
      ;;
    *) positional+=("$arg") ;;
  esac
done

if [ "${#positional[@]}" -ne 1 ]; then
  usage
  exit 64
fi

project="${positional[0]}"

# --maestro is shorthand for the Maestro reviewer instance: same project dir,
# the MAESTRO_WORKFLOW.md file, and the maestro profile. Explicit caller env
# still wins over the shorthand defaults.
if [ "$maestro_mode" -eq 1 ]; then
  SYMPHONY_WORKFLOW_FILE="${SYMPHONY_WORKFLOW_FILE:-MAESTRO_WORKFLOW.md}"
  SYMPHONY_PROFILE="${SYMPHONY_PROFILE:-maestro}"
fi

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

if [ -n "${SYMPHONY_REPO_ROOT:-}" ]; then
  repo_root="$(cd -- "$SYMPHONY_REPO_ROOT" && pwd)"
else
  repo_root="$(cd -- "$script_dir/.." && pwd)"
fi

workflow_dir="$repo_root/workflows/$project"
workflow_name="${SYMPHONY_WORKFLOW_FILE:-WORKFLOW.md}"
case "$workflow_name" in
  ""|*/*) die "SYMPHONY_WORKFLOW_FILE must be a file name, got: $workflow_name" ;;
esac

default_workflow_file="$workflow_dir/WORKFLOW.md"
if [ -L "$default_workflow_file" ]; then
  link_target="$(readlink "$default_workflow_file")"
  namespace="$(basename "$(dirname "$link_target")")"
else
  namespace="$project"
fi
workflow_file="$workflow_dir/$workflow_name"
defaults_env="$repo_root/workflows/$namespace/project.env.defaults"
project_env="$workflow_dir/project.env"
local_env="$workflow_dir/project.env.local"

[ -f "$workflow_file" ] || die "workflow file not found: $workflow_file"
[ -f "$project_env" ] || die "project env file not found: $project_env"

caller_profile="${SYMPHONY_PROFILE:-}"

set -a
[ ! -f "$defaults_env" ] || source "$defaults_env"
source "$project_env"
set +a

if [ -n "$caller_profile" ]; then
  SYMPHONY_PROFILE="$caller_profile"
else
  SYMPHONY_PROFILE="${SYMPHONY_PROFILE:-grandline}"
fi
export SYMPHONY_PROFILE

if [ -z "${SYMPHONY_PROJECT_SLUG:-}" ] && [ -z "${SYMPHONY_PROJECT_SLUGS:-}" ] && [ -z "${SYMPHONY_PROJECT_NAME:-}" ] && [ -z "${SYMPHONY_PROJECT_NAMES:-}" ]; then
  die "SYMPHONY_PROJECT_SLUG, SYMPHONY_PROJECT_SLUGS, SYMPHONY_PROJECT_NAME, or SYMPHONY_PROJECT_NAMES is not set by $project_env"
fi

if [ -z "${SYMPHONY_PROJECT_SLUGS:-}" ] && [ -z "${SYMPHONY_PROJECT_NAMES:-}" ]; then
  [ -n "${SYMPHONY_BASE_BRANCH:-}" ] || die "SYMPHONY_BASE_BRANCH is not set by $project_env"
  [ -n "${SYMPHONY_REPO:-}" ] || die "SYMPHONY_REPO is not set by $project_env"
fi

selected_profile="$SYMPHONY_PROFILE"
profile_env="$HOME/.config/symphony/$SYMPHONY_PROFILE.env"
[ -f "$profile_env" ] || die "profile env file not found: $profile_env"

set -a
source "$profile_env"
source "$project_env"
[ ! -f "$local_env" ] || source "$local_env"
set +a

SYMPHONY_PROFILE="$selected_profile"

[ -n "${LINEAR_API_KEY:-}" ] || die "LINEAR_API_KEY is not set by $profile_env"

configure_github_app_auth

export GH_PROMPT_DISABLED="${GH_PROMPT_DISABLED:-true}"
export SYMPHONY_WORKSPACE_ROOT="${SYMPHONY_WORKSPACE_ROOT:-$HOME/symphony-workspaces}"
export SYMPHONY_MAESTRO_WORKSPACE_ROOT="${SYMPHONY_MAESTRO_WORKSPACE_ROOT:-$SYMPHONY_WORKSPACE_ROOT-maestro}"
export SYMPHONY_PROFILE

# The maestro instance must not fight the main instance for its dashboard
# port (project.env's SYMPHONY_PORT belongs to the main instance); it gets
# a dashboard only when the profile sets SYMPHONY_MAESTRO_PORT.
if [ "$maestro_mode" -eq 1 ]; then
  SYMPHONY_PORT="${SYMPHONY_MAESTRO_PORT:-}"
fi

printf 'symphony-run: starting project=%s profile=%s workflow=%s logs=%s\n' \
  "$project" \
  "$SYMPHONY_PROFILE" \
  "$workflow_file" \
  "$repo_root/elixir/log/symphony.log" >&2

cd "$repo_root/elixir"
mise exec -- mix escript.build >/dev/null
symphony_args=(--i-understand-that-this-will-be-running-without-the-usual-guardrails)
[ -z "${SYMPHONY_PORT:-}" ] || symphony_args+=(--port "$SYMPHONY_PORT")
symphony_args+=("$workflow_file")
exec mise exec -- ./bin/symphony "${symphony_args[@]}"
